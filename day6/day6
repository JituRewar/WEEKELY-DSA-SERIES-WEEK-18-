01_recursion.cpp
#include <iostream>
using namespace std;

long long solve(int n) {

    if(n == 1)
        return 0;

    if(n == 2)
        return 1;

    return (n - 1) *
           (solve(n - 1) +
            solve(n - 2));
}

int main() {

    int n = 4;

    cout << solve(n);

    return 0;
}
02_memoization.cpp
#include <iostream>
#include <vector>
using namespace std;

long long solve(int n, vector<long long>& dp) {

    if(n == 1)
        return 0;

    if(n == 2)
        return 1;

    if(dp[n] != -1)
        return dp[n];

    return dp[n] =
        (n - 1) *
        (solve(n - 1, dp) +
         solve(n - 2, dp));
}

int main() {

    int n = 4;

    vector<long long> dp(n + 1, -1);

    cout << solve(n, dp);

    return 0;
}
03_tabulation.cpp
#include <iostream>
#include <vector>
using namespace std;

long long countDerangements(int n) {

    vector<long long> dp(n + 1);

    dp[1] = 0;
    dp[2] = 1;

    for(int i = 3; i <= n; i++) {

        dp[i] =
            (i - 1) *
            (dp[i - 1] + dp[i - 2]);
    }

    return dp[n];
}

int main() {

    int n = 4;

    cout << countDerangements(n);

    return 0;
}
04_space_optimization.cpp
#include <iostream>
using namespace std;

long long countDerangements(int n) {

    if(n == 1)
        return 0;

    if(n == 2)
        return 1;

    long long prev2 = 0;
    long long prev1 = 1;

    for(int i = 3; i <= n; i++) {

        long long curr =
            (i - 1) *
            (prev1 + prev2);

        prev2 = prev1;
        prev1 = curr;
    }

    return prev1;
}

int main() {

    int n = 4;

    cout << countDerangements(n);

    return 0;
}
