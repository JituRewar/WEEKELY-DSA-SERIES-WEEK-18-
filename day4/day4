01_recursion.cpp
#include <iostream>
#include <vector>
using namespace std;

int solve(vector<int>& arr, int index) {

    if(index == 0)
        return arr[0];

    if(index < 0)
        return 0;

    int take = arr[index] +
               solve(arr, index - 2);

    int notTake = solve(arr, index - 1);

    return max(take, notTake);
}

int main() {

    vector<int> arr = {2,1,4,9};

    cout << solve(arr, arr.size()-1);

    return 0;
}
02_memoization.cpp
#include <iostream>
#include <vector>
using namespace std;

int solve(vector<int>& arr, int index,
          vector<int>& dp) {

    if(index == 0)
        return arr[0];

    if(index < 0)
        return 0;

    if(dp[index] != -1)
        return dp[index];

    int take = arr[index] +
               solve(arr, index - 2, dp);

    int notTake =
        solve(arr, index - 1, dp);

    return dp[index] =
           max(take, notTake);
}

int main() {

    vector<int> arr = {2,1,4,9};

    int n = arr.size();

    vector<int> dp(n, -1);

    cout << solve(arr, n-1, dp);

    return 0;
}
03_tabulation.cpp
#include <iostream>
#include <vector>
using namespace std;

int maximumSum(vector<int>& arr) {

    int n = arr.size();

    vector<int> dp(n);

    dp[0] = arr[0];

    for(int i = 1; i < n; i++) {

        int take = arr[i];

        if(i > 1)
            take += dp[i-2];

        int notTake = dp[i-1];

        dp[i] = max(take, notTake);
    }

    return dp[n-1];
}

int main() {

    vector<int> arr = {2,1,4,9};

    cout << maximumSum(arr);

    return 0;
}
04_space_optimization.cpp
#include <iostream>
#include <vector>
using namespace std;

int maximumSum(vector<int>& arr) {

    int prev = arr[0];
    int prev2 = 0;

    for(int i = 1; i < arr.size(); i++) {

        int take = arr[i];

        if(i > 1)
            take += prev2;

        int notTake = prev;

        int curr = max(take, notTake);

        prev2 = prev;
        prev = curr;
    }

    return prev;
}

int main() {

    vector<int> arr = {2,1,4,9};

    cout << maximumSum(arr);

    return 0;
}
