  #include<bits/stdc++.h>
using namespace std;

//by top-down approach(recurssion + memoization)
int fib0(int n,vector<int> &DP){
    if(n<=1) return n;

    if(DP[n] != -1) return DP[n]; //memoization

     DP[n] = fib0(n-1,DP) + fib0(n-2,DP); //storing
     return DP[n];
}

//by bottom-up approach(tabulation)
int fib1(int n,vector<int> &DP){
    DP[0] = 0;
    DP[1] = 1;

    for(int i=2;i<=n;i++){
        DP[i] = DP[i-1]+DP[i-2];
    }
    return DP[n];

}

    //by space optimization
    int fib2(int n){
    
    int prev1=1;
    int prev2=0;

    for(int i=2;i<=n;i++){
       int curr = prev1+prev2;
        prev2=prev1;
        prev1=curr;
    }
    return prev1;

}

